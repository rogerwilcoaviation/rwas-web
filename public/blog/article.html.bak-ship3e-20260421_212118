<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Article &mdash; Roger Wilco Aviation Services</title>
<style>
* { box-sizing: border-box; margin: 0; padding: 0; }
body { background: #ddd9d2; font-family: Georgia, 'Times New Roman', serif; }
body::before { content: ""; position: fixed; top: 0; left: 0; width: 100vw; height: 100vh; background: url(/newspaper/images/enr_h05.png) center center / cover no-repeat; opacity: 0.25; z-index: 0; pointer-events: none; }
body > * { position: relative; z-index: 1; }
@media (max-width: 749px) { body::before { display: none; } }
.page { max-width: 1200px; margin: 20px auto; background: #f7f4ef; border: 1px solid #1a1a1a; box-shadow: 0 2px 12px rgba(0,0,0,0.15); }

.dateline { display: flex; justify-content: space-between; padding: 5px 20px; border-bottom: 1px solid #1a1a1a; font-family: Arial, sans-serif; font-size: 10px; letter-spacing: 0.08em; text-transform: uppercase; color: #444; }

.masthead { display: flex; align-items: center; justify-content: space-between; padding: 10px 20px; border-bottom: 4px double #1a1a1a; gap: 16px; }
.masthead-logo { width: 60px; height: 60px; object-fit: contain; filter: grayscale(100%); flex-shrink: 0; }
.masthead-center { text-align: center; flex: 1; }
.masthead-name { font-family: Georgia, serif; font-size: 30px; font-weight: 700; letter-spacing: -0.01em; line-height: 1; color: #0a0a0a; margin-bottom: 4px; white-space: nowrap; }
.masthead-rule { border: none; border-top: 1px solid #1a1a1a; margin: 5px 0; }
.masthead-tagline { font-family: Arial, sans-serif; font-size: 9.5px; letter-spacing: 0.05em; color: #444; text-transform: uppercase; white-space: nowrap; }
.masthead-right { font-family: Arial, sans-serif; font-size: 10px; color: #666; text-align: right; flex-shrink: 0; width: 100px; line-height: 1.7; }

.nav { display: flex; border-bottom: 2px solid #1a1a1a; flex-wrap: wrap; }
.nav a { padding: 7px 11px; font-family: Arial, sans-serif; font-size: 10px; letter-spacing: 0.05em; text-transform: uppercase; text-decoration: none; color: #1a1a1a; border-right: 1px solid #1a1a1a; cursor: pointer; }
.nav a:hover, .nav a.active { background: #1a1a1a; color: #f7f4ef; }

.body { padding: 0 20px; }

.article-layout { display: grid; grid-template-columns: minmax(0,1fr) 1px 220px; gap: 0; padding: 16px 0; }
.article-main { padding-right: 16px; }
.article-divider { background: #1a1a1a; }
.article-sidebar { padding-left: 16px; }

.kicker { font-family: Arial, sans-serif; font-size: 9.5px; letter-spacing: 0.14em; text-transform: uppercase; color: #555; margin-bottom: 5px; display: block; }
.headline-xl { font-family: Georgia, serif; font-size: 28px; font-weight: 700; line-height: 1.08; color: #0a0a0a; margin-bottom: 6px; }
.subtitle { font-family: Georgia, serif; font-size: 14px; font-style: italic; line-height: 1.35; color: #444; margin-bottom: 8px; }
.byline { font-family: Arial, sans-serif; font-size: 10px; letter-spacing: 0.08em; text-transform: uppercase; color: #666; margin-bottom: 8px; }
.body-text { font-family: Georgia, serif; font-size: 12.5px; line-height: 1.65; color: #1c1c1c; text-align: justify; }
.body-text + .body-text { margin-top: 8px; }
.drop::first-letter { font-family: Georgia, serif; font-size: 42px; font-weight: 700; float: left; line-height: 0.84; margin: 3px 5px 0 0; color: #0a0a0a; }

.rule { border: none; border-top: 1px solid #1a1a1a; margin: 12px 0; }
.rule-thick { border: none; border-top: 2px solid #1a1a1a; margin: 12px 0; }

.source-box { border: 1px solid #1a1a1a; padding: 8px 10px; margin-top: 14px; background: #ede9e2; }
.source-box-label { font-family: Arial, sans-serif; font-size: 9px; font-weight: 700; letter-spacing: 0.1em; text-transform: uppercase; margin-bottom: 3px; }
.source-box-text { font-family: Georgia, serif; font-size: 11px; color: #555; line-height: 1.5; }
.source-box-text a { color: #1a1a1a; }

.tag-list { margin-top: 12px; }
.tag { display: inline-block; font-family: Arial, sans-serif; font-size: 8.5px; letter-spacing: 0.08em; text-transform: uppercase; padding: 2px 7px; border: 1px solid #1a1a1a; margin: 2px 3px 2px 0; color: #444; }

.sidebar-box { border: 1px solid #1a1a1a; padding: 9px 11px; margin-bottom: 11px; }
.sidebar-box-title { font-family: Arial, sans-serif; font-size: 9.5px; font-weight: 700; letter-spacing: 0.1em; text-transform: uppercase; border-bottom: 1px solid #1a1a1a; padding-bottom: 4px; margin-bottom: 7px; }
.sidebar-item { font-family: Georgia, serif; font-size: 11px; padding: 3px 0; border-bottom: 1px dotted #bbb; line-height: 1.4; }
.sidebar-item:last-child { border-bottom: none; }
.sidebar-item a { color: inherit; text-decoration: none; }
.sidebar-item a:hover { text-decoration: underline; text-underline-offset: 2px; }
.sidebar-item-date { font-family: Arial, sans-serif; font-size: 9px; color: #888; }

.back-link { display: inline-block; font-family: Arial, sans-serif; font-size: 10px; letter-spacing: 0.08em; text-transform: uppercase; color: #1a1a1a; text-decoration: none; padding: 10px 0; }
.back-link:hover { text-decoration: underline; }

.article-hero { margin: 10px 0; cursor: pointer; }
.article-hero-img { width: 100%; max-height: 400px; object-fit: cover; object-position: center top; border: 1px solid #1a1a1a; display: block; transition: opacity 0.15s; }
.article-hero:hover .article-hero-img { opacity: 0.9; }

/* Lightbox */
.lightbox { display: none; position: fixed; top: 0; left: 0; width: 100%; height: 100%; background: rgba(10,10,10,0.92); z-index: 9999; cursor: pointer; align-items: center; justify-content: center; }
.lightbox.active { display: flex; }
.lightbox img { max-width:88%; max-height: 90vh; object-fit: contain; border: 2px solid #f7f4ef; box-shadow: 0 4px 40px rgba(0,0,0,0.5); }
.lightbox-close { position: fixed; top: 14px; right: 20px; font-family: Arial, sans-serif; font-size: 28px; color: #f7f4ef; cursor: pointer; z-index: 10000; line-height: 1; }
.lightbox-close:hover { color: #ccc; }

.cta-box { border: 2px solid #1a1a1a; padding: 12px; text-align: center; margin-top: 11px; background: #ede9e2; }
.cta-title { font-family: Arial, sans-serif; font-size: 11px; font-weight: 700; letter-spacing: 0.06em; text-transform: uppercase; margin-bottom: 4px; }
.cta-text { font-family: Georgia, serif; font-size: 11px; color: #555; margin-bottom: 8px; line-height: 1.5; }
.cta-btn { display: inline-block; background: #1a1a1a; color: #f7f4ef; font-family: Arial, sans-serif; font-size: 9px; letter-spacing: 0.12em; text-transform: uppercase; padding: 5px 14px; text-decoration: none; }

.ornament { text-align: center; color: #999; margin: 10px 0; font-size: 14px; letter-spacing: 0.3em; }

.footer { background: #1a1a1a; color: #c0bbb4; padding: 12px 20px; display: flex; justify-content: space-between; align-items: center; font-family: Arial, sans-serif; font-size: 10px; letter-spacing: 0.07em; text-transform: uppercase; }
.footer-name { font-family: Georgia, serif; font-size: 20px; font-weight: 700; color: #f7f4ef; letter-spacing: 0; text-transform: none; }

.loading { text-align: center; padding: 40px; font-family: Georgia, serif; font-style: italic; color: #888; }

/* ── Mobile responsive ── */
@media (max-width: 768px) {
  .page { margin: 0; border: none; box-shadow: none; }
  .body { padding: 0 12px; }

  .dateline { flex-wrap: wrap; justify-content: center; gap: 4px; padding: 5px 12px; text-align: center; }

  .masthead { flex-direction: column; padding: 10px 12px; gap: 6px; text-align: center; }
  .masthead-logo { width: 48px; height: 48px; }
  .masthead-name { font-size: 22px; white-space: normal; }
  .masthead-tagline { white-space: normal; font-size: 8.5px; line-height: 1.6; }
  .masthead-right { text-align: center; width: auto; }

  .nav { border-bottom: 1px solid #1a1a1a; }
  .nav a { padding: 6px 8px; font-size: 9px; border-right: none; border-bottom: 1px solid #ccc; }
  .nav a.active { border-bottom-color: #1a1a1a; }

  /* Article layout — stack sidebar below */
  .article-layout { grid-template-columns: 1fr; }
  .article-main { padding-right: 0; padding-bottom: 14px; }
  .article-divider { display: none; }
  .article-sidebar { padding-left: 0; padding-top: 14px; border-top: 1px solid #1a1a1a; }

  .headline-xl { font-size: 22px; line-height: 1.15; }
  .subtitle { font-size: 13px; }
  .body-text { font-size: 11.5px; }
  .drop::first-letter { font-size: 32px; }

  .footer { flex-direction: column; gap: 6px; text-align: center; padding: 12px; }
  .footer-name { font-size: 16px; }
}

@media (max-width: 480px) {
  .masthead-name { font-size: 18px; }
  .masthead-logo { width: 40px; height: 40px; }
  .headline-xl { font-size: 20px; }
  .nav a { padding: 5px 7px; font-size: 8.5px; }
}
</style>
</head>
<body>
<div class="page">

  <div class="dateline">
    <span>Aviation News &amp; Updates</span>
    <span>Blog Article</span>
    <span>rogerwilcoaviation.com</span>
  </div>

  <div class="masthead">
    <a href="/"><img class="masthead-logo" src="/images/logo.png" alt="Roger Wilco Aviation Services"></a>
    <div class="masthead-center">
      <div class="masthead-name">Roger Wilco Aviation Services</div>
      <hr class="masthead-rule">
      <div class="masthead-tagline">FAA Cert. Repair Station &nbsp;&middot;&nbsp; Avionics &nbsp;&middot;&nbsp; Airframe &amp; Powerplant &nbsp;&middot;&nbsp; NDT &nbsp;&middot;&nbsp; Fabrication</div>
    </div>
    <div class="masthead-right">
      Cert. No. RWSR491E<br>
      KYKN &middot; Yankton, SD
    </div>
  </div>

  <div class="nav" id="rwas-nav"></div>

  <div class="body">
