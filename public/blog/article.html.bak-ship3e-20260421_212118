    <div id="article-container">
      <div class="loading">Loading article&hellip;</div>
    </div>
  </div>

  <div class="footer">
    <span class="footer-name">Roger Wilco Aviation Services</span>
    <span>&copy; 2026 RWAS &middot; All Rights Reserved</span>
  </div>

</div>

<script>
function formatDate(dateStr) {
  var d = new Date(dateStr + 'T00:00:00');
  var months = ['January','February','March','April','May','June','July','August','September','October','November','December'];
  return months[d.getMonth()] + ' ' + d.getDate() + ', ' + d.getFullYear();
}

function formatDateShort(dateStr) {
  var d = new Date(dateStr + 'T00:00:00');
  var months = ['Jan','Feb','Mar','Apr','May','Jun','Jul','Aug','Sep','Oct','Nov','Dec'];
  return months[d.getMonth()] + ' ' + d.getDate();
}

function categoryLabel(cat) {
  return { 'press-release':'Press Release', 'service-bulletin':'Service Bulletin', 'product-update':'Product Update', 'memo':'Dealer Memo', 'regulatory':'Regulatory' }[cat] || cat;
}

function escapeHtml(str) {
  return String(str)
    .replace(/&/g, '&amp;')
    .replace(/</g, '&lt;')
    .replace(/>/g, '&gt;')
    .replace(/"/g, '&quot;')
    .replace(/'/g, '&#39;');
}

function formatInlineMarkdown(text) {
  var escaped = escapeHtml(text);
  escaped = escaped.replace(/\*\*(.+?)\*\*/g, '<strong>$1</strong>');
  escaped = escaped.replace(/\[(.+?)\]\((https?:\/\/[^\s)]+)\)/g, '<a href="$2" target="_blank" rel="noopener">$1</a>');
  return escaped;
}

function renderMarkdownBody(markdown) {
  var lines = String(markdown || '').replace(/\r\n/g, '\n').split('\n');
  var html = '';
  var paragraph = [];
  var listItems = [];

  function imageMatch(line) {
    return line.match(/^!\[([^\]]*)\]\((https?:\/\/[^\s)]+|\/[^\s)]+)\)$/);
  }

  function flushParagraph() {
    if (!paragraph.length) return;
    var cls = html.indexOf('class="body-text drop"') === -1 ? 'body-text drop' : 'body-text';
    html += '<p class="' + cls + '">' + formatInlineMarkdown(paragraph.join(' ')) + '</p>';
    paragraph = [];
  }

  function flushList() {
    if (!listItems.length) return;
    html += '<ul style="margin:10px 0 10px 22px;">';
    listItems.forEach(function(item) {
      html += '<li class="body-text" style="text-align:left; margin:4px 0;">' + formatInlineMarkdown(item) + '</li>';
    });
    html += '</ul>';
    listItems = [];
  }

  lines.forEach(function(line) {
    var trimmed = line.trim();
    if (!trimmed) {
      flushParagraph();
      flushList();
      return;
    }

    var image = imageMatch(trimmed);
    if (image) {
      flushParagraph();
      flushList();
      html += '<figure style="margin:18px 0;"><img src="' + escapeHtml(image[2]) + '" alt="' + escapeHtml(image[1]) + '" style="width:100%;border:1px solid #1a1a1a;display:block;" onclick="openLightbox(this.src, this.alt)"><figcaption class="kicker" style="margin-top:6px; display:block;">' + escapeHtml(image[1]) + '</figcaption></figure>';
      return;
    }

    if (/^###\s+/.test(trimmed)) {
      flushParagraph();
      flushList();
      html += '<h3 class="headline-md" style="margin-top:14px;">' + formatInlineMarkdown(trimmed.replace(/^###\s+/, '')) + '</h3>';
      return;
    }

    if (/^##\s+/.test(trimmed)) {
      flushParagraph();
      flushList();
      html += '<h2 class="headline-lg" style="font-size:22px; margin-top:14px;">' + formatInlineMarkdown(trimmed.replace(/^##\s+/, '')) + '</h2>';
      return;
    }

    if (/^-\s+/.test(trimmed)) {
      flushParagraph();
      listItems.push(trimmed.replace(/^-\s+/, ''));
      return;
    }

    paragraph.push(trimmed);
  });

  flushParagraph();
  flushList();
  return html;
}

var params = new URLSearchParams(window.location.search);
var articleId = params.get('id');

fetch('/blog-articles.json')
  .then(function(r) { return r.json(); })
  .then(function(data) {
    var articles = data.articles || [];
    var article = articles.find(function(a) { return a.id === articleId; });
    if (!article) {
      document.getElementById('article-container').innerHTML = '<div class="loading">Article not found.</div>';
      return;
    }

    document.title = article.title + ' \u2014 Roger Wilco Aviation Services';

    var html = '<div class="article-layout">';
    html += '<div class="article-main">';
    html += '<span class="kicker">' + categoryLabel(article.category) + ' &middot; ' + formatDate(article.date) + '</span>';
    html += '<h1 class="headline-xl">' + article.title + '</h1>';
    if (article.subtitle) {
      html += '<div class="subtitle">' + article.subtitle + '</div>';
    }
    html += '<div class="byline">' + article.byline + ' &middot; ' + article.author + '</div>';
    if (article.image) {
      html += '<div class="article-hero" onclick="openLightbox(this.querySelector(\'img\').src, this.querySelector(\'img\').alt)"><img src="' + article.image + '" alt="' + (article.image_alt || article.title) + '" class="article-hero-img"></div>';
    }
    html += '<hr class="rule">';
    if (article.body_markdown) {
      html += renderMarkdownBody(article.body_markdown);
    } else {
      html += '<p class="body-text drop">' + article.lead + '</p>';
      (article.body || []).forEach(function(para) {
        html += '<p class="body-text">' + para + '</p>';
      });
    }

    // Source attribution
    if (article.source) {
      html += '<div class="source-box">';
      html += '<div class="source-box-label">Source</div>';
      html += '<div class="source-box-text">' + article.source;
      if (article.source_url) {
        html += ' &mdash; <a href="' + article.source_url + '" target="_blank" rel="noopener">View original &rarr;</a>';
      }
      html += '</div></div>';
    }

    // Tags
    if (article.tags && article.tags.length > 0) {
      html += '<div class="tag-list">';
      article.tags.forEach(function(t) {
        html += '<span class="tag">' + t + '</span>';
      });
      html += '</div>';
    }

    html += '<div class="ornament" style="margin-top:16px;">&#9670; &nbsp; &#9670; &nbsp; &#9670;</div>';
    html += '</div>';

    // Sidebar
    html += '<div class="article-divider"></div>';
    html += '<div class="article-sidebar">';

    // CTA box
    html += '<div class="cta-box">';
    html += '<div class="cta-title">Schedule Service</div>';
    html += '<div class="cta-text">Interested in this product or service? Contact us for pricing, availability, and scheduling.</div>';
    html += '<a class="cta-btn" href="tel:+16052998178">(605) 299-8178</a>';
    html += '</div>';

    // Related articles
    var related = articles.filter(function(a) {
      return a.id !== articleId && a.status === 'published';
    }).sort(function(a, b) { return b.date.localeCompare(a.date); }).slice(0, 5);

    if (related.length > 0) {
      html += '<div class="sidebar-box" style="margin-top:11px;">';
      html += '<div class="sidebar-box-title">More Dispatches</div>';
      related.forEach(function(r) {
        html += '<div class="sidebar-item"><a href="/blog/article.html?id=' + r.id + '">' + r.title.substring(0, 50) + (r.title.length > 50 ? '&hellip;' : '') + '</a><br><span class="sidebar-item-date">' + formatDateShort(r.date) + '</span></div>';
      });
      html += '</div>';
    }

    // Ask Jerry box
    html += '<div class="sidebar-box">';
    html += '<div class="sidebar-box-title">Ask Captain Jerry</div>';
    html += '<div style="font-family:Georgia,serif;font-size:11px;color:#555;line-height:1.5;margin-bottom:6px;">Have questions about this product or bulletin? Captain Jerry is your on-call avionics expert.</div>';
    html += '<a href="https://jerry.rwas.team" style="display:inline-block;background:#1a1a1a;color:#f7f4ef;font-family:Arial,sans-serif;font-size:9px;letter-spacing:0.1em;text-transform:uppercase;padding:4px 10px;text-decoration:none;">Chat with Jerry &rarr;</a>';
    html += '</div>';

    html += '</div></div>';

    document.getElementById('article-container').innerHTML = html;
  })
  .catch(function() {
    document.getElementById('article-container').innerHTML = '<div class="loading">Unable to load article.</div>';
  });
</script>

<!-- Lightbox -->
<div class="lightbox" id="lightbox" onclick="closeLightbox()">
  <span class="lightbox-close" onclick="closeLightbox()">&times;</span>
  <img id="lightbox-img" src="" alt="">
</div>
<script>
function openLightbox(src, alt) {
  var lb = document.getElementById('lightbox');
  var img = document.getElementById('lightbox-img');
  img.src = src;
  img.alt = alt || '';
  lb.classList.add('active');
  document.body.style.overflow = 'hidden';
}
function closeLightbox() {
  document.getElementById('lightbox').classList.remove('active');
  document.body.style.overflow = '';
}
document.addEventListener('keydown', function(e) {
  if (e.key === 'Escape') closeLightbox();
});
</script>
<script src="/jerry-widget.js"></script>
<script src="/js/blog-nav.js"></script>
</body>
</html>
